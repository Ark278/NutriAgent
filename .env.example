# IBM Watsonx.ai Credentials (REQUIRED)
# Get API Key: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# Get Project ID: https://dataplatform.cloud.ibm.com/ → Project → Manage → General
IBM_PROJECT_ID=your_watsonx_project_id_here

# IBM Watsonx.ai endpoint (us-south is default; change for other regions)
IBM_URL=https://au-syd.ml.cloud.ibm.com

# Granite Model to use:
# ibm/granite-3-3-8b-instruct   ← Recommended (best balance)
# ibm/granite-3-8b-instruct     ← Fast & efficient
# ibm/granite-3-2b-instruct     ← Lightweight
MODEL_ID=ibm/granite-3-3-8b-instruct

# Flask Configuration
FLASK_SECRET_KEY=change-me-to-a-strong-random-secret-key
FLASK_DEBUG=false
PORT=5000
